ALLOWED_METHODS=qes
API_SKIP_AUTH=true # only works for local development - first user is selected
WEBHOOK_PRIVATE_
AUTOGRAM_SERVICE_URL=https://ag-service.dev.slovensko.digital
AVM_URL=https://autogram.slovensko.digital

# Federation configuration
FEDERATION_BASE_URL=https://portal.example.com
FEDERATION_ISSUER=https://portal.example.com
FEDERATION_PORTAL_NAME="Autogram Portal"
FEDERATION_PUBLIC_KEY_PEM=
FEDERATION_PRIVATE_KEY_PEM=
FEDERATION_EMAIL_DOMAINS=example.com

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# SMTP Configuration
MAIL_FROM="Autogram Portal LOCAL <noreply@example.com>"
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_AUTHENTICATION=plain
SMTP_ENABLE_STARTTLS_AUTO=true
SMTP_TLS=true

