<%= turbo_frame_tag "bundle_recipients_#{@bundle.uuid}" do %>
  <div class="space-y-6">
    <div class="md:flex items-center justify-between gap-4">
      <div class="flex-1 text-left">
        <h3 class="text-xl font-semibold text-gray-900 mb-2"><%= t('.title') %></h3>
        <p class="text-gray-600"><%= t('.subtitle') %></p>
      </div>
    </div>

    <%# Signing rule configuration - collapsible %>
    <div data-controller="toggle" data-toggle-collapsed-value="true">
      <button type="button"
              data-action="click->toggle#toggle"
              class="flex w-full items-center justify-between rounded-lg border border-gray-200 bg-white px-4 py-3 text-sm font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-inset focus:ring-blue-500 cursor-pointer">
        <span class="flex items-center gap-2 min-w-0">
          <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
          <span class="whitespace-nowrap"><%= t('.signing_rule_label') %></span>
        </span>
        <span class="flex items-center gap-2 shrink-0">
          <span class="hidden md:inline text-xs text-gray-400 max-w-48 truncate">
            <span data-toggle-target="textCollapsed"><%= t(".signing_rule_#{@bundle.signing_rule}") %></span>
            <span data-toggle-target="textExpanded" class="hidden"><%= t(".signing_rule_#{@bundle.signing_rule}") %></span>
          </span>
          <svg data-toggle-target="icon"
               class="w-4 h-4 text-gray-400 transition-transform duration-200"
               fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </span>
      </button>

      <div data-toggle-target="content" class="hidden mt-2">
        <%= form_with model: @bundle, url: bundle_path(@bundle), method: :patch,
              data: { turbo_frame: "bundle_recipients_#{@bundle.uuid}" } do |f| %>
          <%= f.hidden_field :step, value: "signing_rule" %>
          <div class="rounded-lg border border-gray-200 p-4 space-y-3"
               data-controller="signing-rule"
               data-action="change->signing-rule#change">
            <div class="grid grid-cols-1 gap-2">
              <%= render 'shared/radio_button_card',
                    form: f,
                    name: :signing_rule,
                    value: "all",
                    label: t('.signing_rule_all'),
                    description: t('.signing_rule_all_description'),
                    checked: @bundle.signing_rule == "all" %>
              <%= render 'shared/radio_button_card',
                    form: f,
                    name: :signing_rule,
                    value: "any",
                    label: t('.signing_rule_any'),
                    description: t('.signing_rule_any_description'),
                    checked: @bundle.signing_rule == "any" %>
              <%= render 'shared/radio_button_card',
                    form: f,
                    name: :signing_rule,
                    value: "threshold",
                    label: t('.signing_rule_threshold'),
                    description: t('.signing_rule_threshold_description'),
                    checked: @bundle.signing_rule == "threshold" %>
            </div>
            <div data-signing-rule-target="thresholdField"
                 class="<%= 'hidden' unless @bundle.signing_rule == 'threshold' %> rounded-lg bg-gray-50 px-4 py-3">
              <label class="block text-sm font-medium text-gray-700 mb-2"><%= t('.required_signatures_label') %></label>
              <div class="flex items-center gap-2">
                <%= f.number_field :required_signatures,
                      value: @bundle.required_signatures,
                      min: 1,
                      max: [@bundle.recipients.size, 1].max,
                      class: "w-20 px-2 py-1.5 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
                <span class="text-sm text-gray-500"><%= t('.required_signatures_of', count: @bundle.recipients.size) %></span>
              </div>
            </div>
            <%= f.submit t('actions.save'),
                  class: "inline-flex items-center px-3 py-1.5 border border-transparent cursor-pointer text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
          </div>
        <% end %>
      </div>
    </div>

    <div class="space-y-3">
      <% @bundle.recipients.order(:created_at).select(&:persisted?).each do |recipient| %>
        <div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
          <div class="px-4 py-3.5">
            <div class="flex items-start gap-3">
              <div class="h-9 w-9 rounded-lg bg-blue-50 flex items-center justify-center shrink-0 mt-0.5">
                <svg class="h-5 w-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 8.25v7.5a2.25 2.25 0 01-2.25 2.25H4.5a2.25 2.25 0 01-2.25-2.25v-7.5m19.5 0-8.69 5.216a2.25 2.25 0 01-2.122 0L2.25 8.25m19.5 0A2.25 2.25 0 0019.5 6H4.5a2.25 2.25 0 00-2.25 2.25" />
                </svg>
              </div>
              <div class="flex-1 min-w-0">
                <div class="flex flex-wrap items-center gap-2">
                  <div class="text-base font-semibold text-gray-900 break-words">
                    <%= recipient.display_name %>
                  </div>
                  <div>
                    <%= recipient_status_badge(recipient) %>
                  </div>
                </div>

                <div class="mt-2.5 flex flex-wrap items-center gap-x-5 gap-y-2 text-sm">
                  <% if recipient.notifiable? && @bundle.author.feature_enabled?(:real_emails) %>
                    <%= button_to notify_bundle_recipient_path(@bundle, recipient),
                          method: :post,
                          class: "text-blue-600 underline hover:text-blue-800 hover:underline cursor-pointer font-medium",
                          form: { data: { turbo_frame: "bundle_recipients_#{@bundle.uuid}" } } do %>
                      <%= t('.send_invitation') %>
                    <% end %>
                  <% end %>

                  <% if recipient.removable? %>
                    <%= button_to bundle_recipient_path(@bundle, recipient),
                          method: :delete,
                          class: "text-red-600 underline hover:text-red-800 hover:underline cursor-pointer font-medium",
                          form: { data: { turbo_frame: "bundle_recipients_#{@bundle.uuid}" } } do %>
                      <%= t('actions.remove') %>
                    <% end %>
                  <% end %>

                  <div data-controller="clipboard" data-clipboard-text-value="<%= sign_bundle_url(@bundle, recipient: recipient.uuid) %>">
                    <%= button_tag type: "button",
                          class: "text-gray-500 underline hover:text-gray-700 hover:underline cursor-pointer font-medium",
                          data: { action: "clipboard#copyToClipboard" } do %>
                      <%= t('.copy_to_clipboard') %>
                    <% end %>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <%= form_with model: @bundle.recipients.build,
          url: bundle_recipients_path(@bundle),
          method: :post,
          data: { turbo_frame: "bundle_recipients_#{@bundle.uuid}" } do |form| %>
      <label class="flex items-center text-sm font-medium text-gray-700 mb-2">
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
        </svg>
        <%= t('.email_label') %>
      </label>
      <% if local_assigns[:recipient_error].present? %>
        <div class="p-3 mb-4 bg-red-50 border border-red-200 rounded-md">
          <p class="text-sm text-red-600"><%= recipient_error %></p>
        </div>
      <% end %>
      <div class="flex items-center gap-2">

        <%= form.email_field :email,
              placeholder: t('.email_placeholder'),
              class: "flex-1 px-3 py-2 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-blue-500 focus:border-blue-500",
              required: true %>
        <%= form.submit t('actions.add'),
              class: "inline-flex items-center px-4 py-2 border border-transparent cursor-pointer text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
      </div>
      <p class="mt-2 text-sm text-gray-500"><%= t('.email_help') %></p>
    <% end %>
  </div>
<% end %>