<% contract = local_assigns.fetch(:contract, @contract) %>
<% back_path = local_assigns.key?(:back_path) ? local_assigns[:back_path] : actions_contract_path(contract) %>
<% target_level = local_assigns[:target_level].presence&.upcase || contract.available_extension_target_levels.first %>
<% frame_id = local_assigns[:frame_id] || "contract_actions_#{contract.uuid}" %>

<%= turbo_frame_tag frame_id do %>
  <div class="w-full">
    <% if current_user && target_level.present? %>
      <div class="mb-6 text-center lg:text-left">
        <h3 class="text-lg font-semibold text-gray-900 mb-2"><%= t(".levels.#{target_level.downcase}.title") %></h3>
        <p class="text-gray-600"><%= t(".levels.#{target_level.downcase}.subtitle") %></p>
      </div>
      <%= form_with url: extend_signatures_contract_path(contract),
                    method: :post,
                    local: true,
                    class: "space-y-6",
                    data: { turbo_frame: "_top", controller: "form-submit", action: "submit->form-submit#handleSubmit" } do |form| %>
        <%= hidden_field_tag :target_level, target_level %>
        <div class="flex flex-col sm:flex-row gap-8">
          <% if back_path.present? %>
            <%= link_to back_path, class: "flex-1 inline-flex justify-center items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" do %>
              <%= t('documents.new.actions.back') %>
            <% end %>
          <% end %>
          <%= submit_tag t(".levels.#{target_level.downcase}.button"),
                      class: "#{back_path.present? ? 'flex-1' : 'w-full'} inline-flex justify-center items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500",
                      data: { "form-submit-target": "submitButton", turbo_frame: "_top" } %>
        </div>
      <% end %>
    <% end %>
  </div>
<% end %>
