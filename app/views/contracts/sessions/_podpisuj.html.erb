<% session_token = SessionAccessToken.generate(contract: @contract, session: @session) %>

<div
  data-controller="signers--podpisuj"
  data-signers--podpisuj-signed-document-path-value="<%= upload_contract_session_path(@contract, @session, session_token: session_token) %>"
>
  <% if params[:embedded] %>
    <div class="w-full space-y-1">
      <h3 class="text-lg font-semibold text-gray-900"><%= t('.title') %></h3>
      <p class="text-sm text-gray-600"><%= t('.subtitle') %></p>
    </div>
  <% else %>
    <div class="px-6 py-5">
      <h1 class="text-3xl font-bold text-gray-900"><%= t('.title') %></h1>
      <p class="text-sm text-gray-600 mt-1"><%= t('.subtitle') %></p>
    </div>
  <% end %>

  <div class="space-y-6 py-6 <%= 'px-6' unless params[:embedded] %>">
    <%= render 'shared/info', title: t('.instructions_title'), content: t('.instructions') %>

    <div class="bg-white border border-gray-200 rounded-lg p-6 space-y-3">
      <div class="flex items-start gap-3">
        <div class="flex-shrink-0 w-8 h-8 bg-blue-50 text-blue-600 rounded-full flex items-center justify-center font-bold text-sm">1</div>
        <div class="flex-1">
          <h3 class="font-semibold text-gray-900"><%= t('.download_title') %></h3>
          <p class="text-sm text-gray-600 mb-3"><%= t('.download_desc') %></p>
          <a href="<%= download_contract_session_path(@contract, @session, session_token: session_token) %>" target="_blank" rel="noopener"
             class="inline-flex items-center px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-md hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 mr-2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
            </svg>
            <%= t('.download_button') %>
          </a>
        </div>
      </div>
    </div>

    <div class="bg-white border border-gray-200 rounded-lg p-6 space-y-3">
      <div class="flex items-start gap-3">
        <div class="flex-shrink-0 w-8 h-8 bg-blue-50 text-blue-600 rounded-full flex items-center justify-center font-bold text-sm">2</div>
        <div class="flex-1">
          <h3 class="font-semibold text-gray-900"><%= t('.upload_title') %></h3>
          <p class="text-sm text-gray-600 mb-3"><%= t('.upload_desc') %></p>

          <label data-action="dragover->signers--podpisuj#dragover dragleave->signers--podpisuj#dragleave drop->signers--podpisuj#drop"
                 data-signers--podpisuj-target="dropzone"
                 class="flex flex-col items-center justify-center w-full border-2 border-dashed border-gray-300 rounded-lg p-8 cursor-pointer hover:border-blue-400 hover:bg-blue-50 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-10 h-10 text-gray-400 mb-3">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5" />
            </svg>
            <span class="text-sm text-gray-600"><%= t('.upload_dropzone') %></span>
            <input type="file" class="sr-only" data-signers--podpisuj-target="input" data-action="change->signers--podpisuj#fileSelected">
          </label>

          <div class="hidden mt-3" data-signers--podpisuj-target="status">
            <p class="text-sm text-gray-700" data-signers--podpisuj-target="statusMessage"></p>
          </div>

          <div class="hidden mt-3 text-sm text-red-700" data-signers--podpisuj-target="error"></div>
        </div>
      </div>
    </div>
  </div>
</div>
