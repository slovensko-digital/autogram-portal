<div
  data-controller="signers--autogram"
  data-signers--autogram-autogram-parameters-path-value="<%= parameters_contract_session_path(@contract, @session) %>"
  data-signers--autogram-signed-document-path-value="<%= upload_contract_session_path(@contract, @session) %>"
  data-signers--autogram-sdk-path-value="<%= javascript_path('autogram-sdk') %>"
>
  <!-- Header -->
  <div class="px-6 py-5">
    <h1 class="text-3xl font-bold text-gray-900"><%= t('.title') %></h1>
    <p class="text-sm text-gray-600 mt-1"><%= t('.subtitle') %></p>
  </div>

  <!-- Main content area with two columns -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 p-6">
    <!-- Left column: Instructions -->
    <div class="space-y-6 border border-gray-200 rounded-lg p-6">
      <!-- Numbered steps -->
      <div class="space-y-4">
        <div class="flex items-start gap-3">
          <div class="flex-shrink-0 w-8 h-8 bg-blue-50 text-blue-600 rounded-full flex items-center justify-center font-bold text-sm">
            1
          </div>
          <div class="flex-1">
            <h3 class="font-semibold text-gray-900"><%= t('.step1_title') %></h3>
            <p class="text-sm text-gray-600 mt-1"><%= t('.step1_desc_html', download_url: 'https://sluzby.slovensko.digital/autogram/#download') %></p>
          </div>
        </div>

        <div class="flex items-start gap-3">
          <div class="flex-shrink-0 w-8 h-8 bg-blue-50 text-blue-600 rounded-full flex items-center justify-center font-bold text-sm">
            2
          </div>
          <div class="flex-1">
            <h3 class="font-semibold text-gray-900"><%= t('.step2_title') %></h3>
            <p class="text-sm text-gray-600 mt-1"><%= t('.step2_desc') %></p>
          </div>
        </div>

        <div class="flex items-start gap-3">
          <div class="flex-shrink-0 w-8 h-8 bg-blue-50 text-blue-600 rounded-full flex items-center justify-center font-bold text-sm">
            3
          </div>
          <div class="flex-1">
            <h3 class="font-semibold text-gray-900"><%= t('.step3_title') %></h3>
            <p class="text-sm text-gray-600 mt-1"><%= t('.step3_desc') %></p>
          </div>
        </div>

        <div class="flex items-start gap-3">
          <div class="flex-shrink-0 w-8 h-8 bg-blue-50 text-blue-600 rounded-full flex items-center justify-center font-bold text-sm">
            4
          </div>
          <div class="flex-1">
            <h3 class="font-semibold text-gray-900"><%= t('.step4_title') %></h3>
            <p class="text-sm text-gray-600 mt-1"><%= t('.step4_desc') %></p>
          </div>
        </div>

        <div class="flex items-start gap-3">
          <div class="flex-shrink-0 w-8 h-8 bg-blue-50 text-blue-600 rounded-full flex items-center justify-center font-bold text-sm">
            5
          </div>
          <div class="flex-1">
            <h3 class="font-semibold text-gray-900"><%= t('.step5_title') %></h3>
            <p class="text-sm text-gray-600 mt-1"><%= t('.step5_desc') %></p>
          </div>
        </div>

        <div class="flex items-start gap-3">
          <div class="flex-shrink-0 w-8 h-8 bg-blue-50 text-blue-600 rounded-full flex items-center justify-center font-bold text-sm">
            6
          </div>
          <div class="flex-1">
            <h3 class="font-semibold text-gray-900"><%= t('.step6_title') %></h3>
            <p class="text-sm text-gray-600 mt-1"><%= t('.step6_desc') %></p>
          </div>
        </div>
      </div>
    </div>

    <!-- Right column: Progress indicator -->
    <div class="border border-gray-200 rounded-lg p-6">
      <!-- Central status icon and message -->
      <div class="flex flex-col items-center justify-center mb-8">
        
        <!-- Normal signing state -->
        <div data-signers--autogram-target="stateNormal">
          <div class="mb-4 flex justify-center">
            <svg class="animate-spin text-blue-600" style="width: 64px; height: 64px;" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" preserveAspectRatio="xMidYMid meet">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2" fill="none"></circle>
              <path class="opacity-75" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" d="M12 2 A 10 10 0 0 1 22 12"></path>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 text-center mb-2">
            <%= t('.progress_title') %>
          </h3>
          <p class="text-sm text-gray-600 text-center">
            <%= t('.progress_subtitle') %>
          </p>
        </div>

        <!-- App not installed state -->
        <div class="hidden" data-signers--autogram-target="stateNotInstalled">
          <div class="mb-4 flex justify-center">
            <div class="w-16 h-16 bg-red-100 rounded-full flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-10 h-10 text-red-600">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
              </svg>
            </div>
          </div>
          <h3 class="text-lg font-semibold text-red-900 text-center mb-2">
            <%= t('.not_installed_title') %>
          </h3>
          <div class="flex flex-col items-center">
            <p class="text-sm text-red-700 text-center mb-4">
              <%= t('.not_installed_desc') %>
            </p>
            <a href="https://sluzby.slovensko.digital/autogram/#download" target="_blank" class="inline-flex items-center px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-md hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 mr-2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
              </svg>
              <%= t('.not_installed_download') %>
            </a>
          </div>
        </div>

        <!-- Cancelled state -->
        <div class="hidden" data-signers--autogram-target="stateCancelled">
          <div class="mb-4 flex justify-center">
            <div class="w-16 h-16 bg-yellow-100 rounded-full flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-10 h-10 text-yellow-600">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </div>
          </div>
          <h3 class="text-lg font-semibold text-yellow-900 text-center mb-2">
            <%= t('.cancelled_title') %>
          </h3>
          <p class="text-sm text-yellow-700 text-center">
            <%= t('.cancelled_desc') %>
          </p>
        </div>

        <!-- Error state -->
        <div class="hidden" data-signers--autogram-target="stateError">
          <div class="mb-4 flex justify-center">
            <div class="w-16 h-16 bg-red-100 rounded-full flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-10 h-10 text-red-600">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </div>
          </div>
          <h3 class="text-lg font-semibold text-red-900 text-center mb-2">
            <%= t('.error_title') %>
          </h3>
          <p class="text-sm text-red-700 text-center" data-signers--autogram-target="errorMessage">
            <%= t('.error_desc') %>
          </p>
        </div>
      </div>

      <!-- Progress bar -->
      <div class="mb-6">
        <div class="flex justify-between text-sm text-gray-600 mb-2">
          <span><%= t('.progress_label') %></span>
          <span data-signers--autogram-target="progressPercent">0%</span>
        </div>
        <div class="w-full bg-gray-200 rounded-full h-2">
          <div class="bg-blue-600 h-2 rounded-full transition-all duration-500" style="width: 0%" data-signers--autogram-target="progressBar"></div>
        </div>
      </div>

      <!-- Status items -->
      <div class="space-y-3">
        <div class="flex items-center gap-3 p-3 bg-white border border-blue-200 rounded-lg" data-signers--autogram-target="statusChecking">
          <div class="flex-shrink-0" style="width: 24px; height: 24px;">
            <svg class="animate-spin text-blue-600" style="width: 24px; height: 24px;" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" preserveAspectRatio="xMidYMid meet">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
          </div>
          <span class="text-sm font-medium text-gray-600"><%= t('.status_checking') %></span>
        </div>

        <div class="flex items-center gap-3 p-3 bg-gray-100 border border-gray-200 rounded-lg opacity-50" data-signers--autogram-target="statusStarting">
          <div class="flex-shrink-0" style="width: 24px; height: 24px;">
            <div style="width: 24px; height: 24px;" class="bg-gray-400 rounded-full"></div>
          </div>
          <span class="text-sm font-medium text-gray-600"><%= t('.status_starting') %></span>
        </div>

        <div class="flex items-center gap-3 p-3 bg-gray-100 border border-gray-200 rounded-lg opacity-50" data-signers--autogram-target="statusSending">
          <div class="flex-shrink-0" style="width: 24px; height: 24px;">
            <div style="width: 24px; height: 24px;" class="bg-gray-400 rounded-full"></div>
          </div>
          <span class="text-sm font-medium text-gray-600"><%= t('.status_sending') %></span>
        </div>

        <div class="flex items-center gap-3 p-3 bg-gray-100 border border-gray-200 rounded-lg opacity-50" data-signers--autogram-target="statusWaiting">
          <div class="flex-shrink-0" style="width: 24px; height: 24px;">
            <div style="width: 24px; height: 24px;" class="bg-gray-400 rounded-full"></div>
          </div>
          <span class="text-sm font-medium text-gray-600"><%= t('.status_waiting') %></span>
        </div>

        <div class="flex items-center gap-3 p-3 bg-gray-100 border border-gray-200 rounded-lg opacity-50" data-signers--autogram-target="statusSigned">
          <div class="flex-shrink-0" style="width: 24px; height: 24px;">
            <div style="width: 24px; height: 24px;" class="bg-gray-400 rounded-full"></div>
          </div>
          <span class="text-sm font-medium text-gray-600"><%= t('.status_signed') %></span>
        </div>
      </div>
    </div>
  </div>

  <!-- Footer with cancel button -->
  <div class="border-t border-gray-200 px-6 py-4">
    <%= link_to signature_apps_contract_path(@contract, recipient: @recipient, iframe: params[:iframe]),
                class: "inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500",
                data: { turbo_method: :get } do %>
      <%= t('.cancel') %>
    <% end %>
  </div>
</div>
