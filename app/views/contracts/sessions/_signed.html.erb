<% @session ||= session %>

<div class="p-8 sm:py-40">
  <div class="border border-gray-200 rounded-lg p-8">
    <div class="text-center mb-6">
      <div class="inline-flex items-center justify-center w-16 h-16 bg-green-100 rounded-full mb-4">
        <svg class="h-8 w-8 text-green-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
        </svg>
      </div>
      <h3 class="text-2xl font-bold text-gray-900 mb-2"><%= t('.title') %></h3>
      <p class="text-sm text-gray-600"><%= t('.message') %></p>
    </div>
    <div class="mt-2 flex justify-center">
      <% if @session.contract.bundle.present? %>
        <%= link_to t('.view_bundle'), sign_bundle_path(@session.contract.bundle, recipient: @session.recipient&.uuid),
              class: "inline-flex text-center rounded-lg bg-blue-600 px-4 py-3 text-sm font-semibold text-white hover:bg-blue-700" %>
      <% else %>
        <%= link_to t('.view_contract'), contract_path(@session.contract),
              class: "inline-flex text-center rounded-lg bg-blue-600 px-4 py-3 text-sm font-semibold text-white hover:bg-blue-700" %>
      <% end %>
    </div>
  </div>
</div>
<script>
  window.parent.postMessage(
    {
      type: 'agp-custom-event',
      status: 'document-signed',
      contract_id: '<%= @session.contract.uuid %>',
      bundle_id: '<%= @session.contract&.bundle&.uuid %>'
    }, '*');
  </script>
