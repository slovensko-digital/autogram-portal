<% @session ||= session %>

<% inline_bundle_success = @session.inline_bundle_success? %>
<% iframe_completion = @session.close_iframe_after_completion? %>

<% if inline_bundle_success %>
  <div class="w-full rounded-lg border border-green-200 bg-green-50 p-4">
    <div class="flex items-start gap-3">
      <div class="mt-0.5 inline-flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-full bg-green-100">
        <svg class="h-5 w-5 text-green-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
        </svg>
      </div>
      <div>
        <h3 class="text-base font-semibold text-green-900"><%= t('.title') %></h3>
        <p class="mt-1 text-sm text-green-800"><%= t('.bundle_progress_message') %></p>
      </div>
    </div>
  </div>
<% else %>
  <div class="p-8 sm:py-40">
    <div class="border border-gray-200 rounded-lg p-8">
      <div class="text-center mb-6">
        <div class="inline-flex items-center justify-center w-16 h-16 bg-green-100 rounded-full mb-4">
          <svg class="h-8 w-8 text-green-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
          </svg>
        </div>
        <h3 class="text-2xl font-bold text-gray-900 mb-2"><%= t('.title') %></h3>
        <p class="text-sm text-gray-600"><%= iframe_completion ? t('.iframe_message') : t('.message') %></p>
      </div>

      <% unless iframe_completion %>
        <div class="mt-2 flex justify-center">
          <% if @session.contract.bundle.present? %>
            <%= link_to t('.view_bundle'), sign_bundle_path(@session.contract.bundle, recipient: @session.recipient&.uuid, iframe: @session.iframe_param),
                  class: "inline-flex text-center rounded-lg bg-blue-600 px-4 py-3 text-sm font-semibold text-white hover:bg-blue-700" %>
          <% else %>
            <%= link_to t('.view_contract'), contract_path(@session.contract),
                  class: "inline-flex text-center rounded-lg bg-blue-600 px-4 py-3 text-sm font-semibold text-white hover:bg-blue-700" %>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<% if @session.iframe_param.present? %>
  <script>
    window.parent.postMessage(<%= raw(json_escape(@session.completion_event_payload.to_json)) %>, '*')
  </script>
<% end %>
