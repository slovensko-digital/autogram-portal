<% @session ||= session %>

<div class="p-8 sm:py-40">
  <div class="border border-gray-200 rounded-lg p-8">
    <div class="text-center mb-6">
      <div class="inline-flex items-center justify-center w-16 h-16 bg-red-100 rounded-full mb-4">
        <svg class="h-8 w-8 text-red-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" />
        </svg>
      </div>
      <h3 class="text-2xl font-bold text-gray-900 mb-2"><%= t('.title') %></h3>
      <p class="text-sm text-gray-600"><%= t('.message') %></p>
      <p class="text-sm text-gray-600 mt-4"><%= @session.error_message %></p>
    </div>
  </div>
</div>
<script>
  window.parent.postMessage(
    {
      type: 'agp-custom-event',
      status: 'sign-error',
      contract_id: '<%= @session.contract.uuid %>',
      bundle_id: '<%= @session.contract&.bundle&.uuid %>',
      error_message: '<%= @session.error_message %>'
    }, '*');
</script>
