<% if params[:embedded] %>
  <div class="w-full space-y-1">
    <h3 class="text-lg font-semibold text-gray-900"><%= t('.title') %></h3>
    <p class="text-sm text-gray-600"><%= t('.subtitle') %></p>
  </div>
<% else %>
  <div class="px-6 py-5 hidden md:block">
    <h1 class="text-3xl font-bold text-gray-900"><%= t('.title') %></h1>
    <p class="text-sm text-gray-600 mt-1"><%= t('.subtitle') %></p>
  </div>
<% end %>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 py-6 <%= 'px-6' unless params[:embedded] %>">
  <div class="space-y-6 bg-white border border-gray-200 rounded-lg p-6">
    <div class="space-y-4">
      <% (1..4).each do |i| %>
        <div class="flex items-start gap-3">
          <div class="flex-shrink-0 w-8 h-8 mt-1 bg-blue-50 text-blue-600 rounded-full flex items-center justify-center font-bold text-sm">
            <%= i %>
          </div>
          <div class="flex-1">
            <h3 class="font-semibold text-gray-900"><%= t(".step#{i}_title") %></h3>
            <p class="text-sm text-gray-600"><%= t(".step#{i}_desc") %></p>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <div class="space-y-6 md:border md:border-gray-200 bg-white md:rounded-lg md:p-6">
    <% if @session.error_message.present? %>
      <div class="rounded-lg border border-red-200 bg-red-50 p-4">
        <p class="text-sm font-medium text-red-900"><%= t('.error_title') %></p>
        <p class="mt-2 text-sm text-red-800"><%= @session.error_message %></p>
      </div>
    <% end %>

    <div class="rounded-lg border border-blue-100 bg-blue-50 p-4">
      <p class="text-sm font-medium text-blue-900"><%= t('.channel_label') %></p>
      <p class="mt-1 text-sm text-blue-800"><%= t('.channel_sms') %></p>
    </div>

    <div class="rounded-lg border border-gray-200 p-4">
      <p class="text-sm font-medium text-gray-900"><%= t('.recipient_phone_label') %></p>
      <p class="mt-1 text-lg font-semibold text-gray-900"><%= @session.recipient_masked_mobile_phone %></p>
      <p class="mt-2 text-sm text-gray-600"><%= t('.recipient_phone_help') %></p>
    </div>

    <% if @session.verification_verified? %>
      <div class="rounded-lg border border-green-200 bg-green-50 p-4">
        <h3 class="text-sm font-semibold text-green-900"><%= t('.verified_title') %></h3>
        <p class="mt-2 text-sm text-green-800"><%= t('.verified_body') %></p>
        <p class="mt-3 text-xs text-green-700"><%= t('.evidence_reference_label') %>: <span class="font-mono"><%= @session.signature_evidence_record&.public_reference %></span></p>
      </div>

      <% if @session.ready_for_server_signing? %>
        <div class="rounded-lg border border-gray-200 p-4 space-y-4">
          <div>
            <h3 class="text-sm font-semibold text-gray-900"><%= t('.complete_signing_title') %></h3>
            <p class="mt-2 text-sm text-gray-700"><%= t('.complete_signing_body') %></p>
          </div>

          <%= button_to t('.complete_signing_button'), complete_signing_contract_session_path(@contract, @session, recipient: @recipient&.uuid, iframe: params[:iframe], embedded: params[:embedded], skip_method_choice: params[:skip_method_choice]), method: :post, class: "inline-flex items-center justify-center rounded-md border border-transparent bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2" %>
        </div>
      <% end %>
    <% elsif @session.verification_requested? %>
      <div class="rounded-lg border border-gray-200 p-4 space-y-4">
        <div>
          <h3 class="text-sm font-semibold text-gray-900"><%= t('.sms_sent_title') %></h3>
          <p class="mt-2 text-sm text-gray-700"><%= t('.sms_sent_body') %></p>
        </div>

        <%= form_with url: verify_verification_contract_session_path(@contract, @session, recipient: @recipient&.uuid, iframe: params[:iframe], embedded: params[:embedded], skip_method_choice: params[:skip_method_choice]), method: :post, class: "space-y-3" do |form| %>
          <div>
            <%= form.label :verification_code, t('.verification_code_label'), class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= form.text_field :verification_code,
                  name: :verification_code,
                  placeholder: t('.verification_code_placeholder'),
                  class: "w-full px-3 py-2 text-sm bg-white border border-gray-300 rounded-md focus:outline-none focus:ring-blue-500 focus:border-blue-500",
                  autocomplete: "one-time-code",
                  inputmode: "numeric" %>
          </div>

          <div class="flex flex-col gap-3 sm:flex-row">
            <%= form.submit t('.verify_code_button'), class: "inline-flex items-center justify-center rounded-md border border-transparent bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2" %>
            <%= button_to t('.resend_code_button'), request_verification_contract_session_path(@contract, @session, recipient: @recipient&.uuid, iframe: params[:iframe], embedded: params[:embedded], skip_method_choice: params[:skip_method_choice]), method: :post, form_class: "contents", class: "inline-flex items-center justify-center rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2" %>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="rounded-lg border border-gray-200 p-4 space-y-4">
        <div>
          <h3 class="text-sm font-semibold text-gray-900"><%= t('.request_code_title') %></h3>
          <p class="mt-2 text-sm text-gray-700"><%= t('.request_code_body') %></p>
        </div>

        <%= button_to t('.request_code_button'), request_verification_contract_session_path(@contract, @session, recipient: @recipient&.uuid, iframe: params[:iframe], embedded: params[:embedded], skip_method_choice: params[:skip_method_choice]), method: :post, class: "inline-flex items-center justify-center rounded-md border border-transparent bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2" %>
      </div>
    <% end %>

    <div class="rounded-lg border border-amber-200 bg-amber-50 p-4">
      <h3 class="text-sm font-semibold text-amber-900"><%= t('.beta_title') %></h3>
      <p class="mt-2 text-sm text-amber-800"><%= t(@session.ready_for_server_signing? ? '.beta_body_signing' : '.beta_body') %></p>
    </div>
  </div>
</div>