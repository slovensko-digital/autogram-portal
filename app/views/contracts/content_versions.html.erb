<main>
  <div class="mx-auto max-w-5xl px-6 pb-24 pt-10 lg:px-8">
    <div class="mb-6 flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
      <div>
        <%= link_to contract_path(@contract), class: "inline-flex items-center text-sm font-medium text-blue-600 hover:text-blue-500 hover:underline mb-3" do %>
          <svg class="mr-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
          </svg>
          <%= t('.back_to_contract') %>
        <% end %>
        <h1 class="text-3xl font-bold text-gray-900"><%= t('.title') %></h1>
        <p class="mt-1 text-sm text-gray-500"><%= t('.subtitle') %></p>
      </div>
      <% if current_user&.archivation_enabled? && @contract.signed_document.attached? %>
        <div class="flex-shrink-0">
          <%= link_to signed_document_contract_path(@contract),
                      class: "inline-flex items-center px-4 py-2 border border-transparent rounded-md text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" do %>
            <%= t('.download_latest') %>
          <% end %>
        </div>
      <% end %>
    </div>

    <% if @content_versions.any? %>
      <div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
        <div class="divide-y divide-gray-100">
          <% @content_versions.each do |version| %>
            <div class="flex items-center gap-3 px-4 py-4 hover:bg-gray-50 transition-colors">
              <div class="h-9 w-9 rounded-lg bg-blue-50 flex items-center justify-center shrink-0">
                <svg class="h-5 w-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9z" />
                </svg>
              </div>
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 flex-wrap">
                  <span class="text-sm font-semibold text-gray-900"><%= version.filename %></span>
                  <% if version == @contract.latest_content_version %>
                    <%= render 'shared/badge', color: 'green', label: t('.current_version') %>
                  <% end %>
                </div>
                <div class="mt-0.5 flex items-center gap-3 text-xs text-gray-400 flex-wrap">
                  <span><%= t('.version_label') %> <%= version.version_number %></span>
                  <span><%= t('.origin_label') %>: <%= t(".origins.#{version.origin}", default: version.origin.humanize) %></span>
                  <span><%= t('.created_at_label') %>: <%= l(version.created_at, format: :short) %></span>
                </div>
              </div>
              <div class="flex items-center gap-6 shrink-0 justify-end">
                <%= link_to t('.download_version'), rails_blob_path(version.file, disposition: 'attachment'),
                            class: "underline text-sm font-medium text-blue-600 hover:text-blue-700 transition-colors" %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% else %>
      <div class="bg-white rounded-lg border border-gray-200 text-center py-16">
        <svg class="mx-auto h-12 w-12 text-gray-300" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9z" />
        </svg>
        <h3 class="mt-3 text-sm font-semibold text-gray-900"><%= t('.empty_title') %></h3>
        <p class="mt-1 text-sm text-gray-500"><%= t('.empty_message') %></p>
      </div>
    <% end %>
  </div>
</main>