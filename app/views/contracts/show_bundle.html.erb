<%= turbo_frame_tag @contract do %>
  <%= render 'contracts/visualization_with_toggle', contract: @contract %>

  <%= turbo_frame_tag "signature_validation_#{@contract.uuid}",
            src: validate_contract_path(@contract),
            loading: "lazy",
            class: "w-full" do %>
    <div class="w-full">
      <div class="rounded-lg bg-gray-50 border border-gray-200 p-4">
        <div class="flex items-center">
          <svg class="animate-spin h-5 w-5 text-gray-500 mr-3" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
          <span class="text-gray-600"><%= t('contracts.signature_validation.validating') %></span>
        </div>
      </div>
    </div>
  <% end %>

  <%= render("layouts/flash", flash: flash) %>

  <% if @contract.bundle.author == current_user %>
    <div class="mt-4 flex justify-end space-x-2">
      <% if @contract.signed_document.attached? %>
        <%= link_to signed_document_contract_path(@contract), data: { turbo: "false" },
              class: "inline-flex justify-center items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 cursor-pointer focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" do %>
          <%= t('contracts.download_actions.download_button') %>
        <% end %>
      <% end %>

      <% if current_user.signature_extension_allowed? && @contract.extendable_signatures?(target_level: 'T') %>
        <%= form_with url: extend_signatures_contract_path(@contract), method: :post, local: true do |form| %>
          <%= form.hidden_field :target_level, value: 'T' %>
          <%= form.submit t('documents.new.actions.add_timestamp.title'),
                          class: "items-center w-full sm:w-auto px-4 py-2 border border-blue-300 text-sm font-medium rounded-md text-blue-700 bg-white cursor-pointer hover:bg-blue-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500",
                          data: { "form-submit-target": "submitButton" } %>
        <% end %>
      <% end %>

      <% if current_user.signature_extension_allowed? && @contract.extendable_signatures?(target_level: 'LTA') %>
        <%= form_with url: extend_signatures_contract_path(@contract), method: :post, local: true do |form| %>
          <%= form.hidden_field :target_level, value: 'LTA' %>
          <%= form.submit t('documents.new.actions.archive.title'),
                          class: "items-center w-full sm:w-auto px-4 py-2 border border-blue-300 text-sm font-medium rounded-md text-blue-700 bg-white cursor-pointer hover:bg-blue-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500",
                          data: { "form-submit-target": "submitButton" } %>
        <% end %>
      <% end %>
    </div>
  <% end %>
<% end %>
