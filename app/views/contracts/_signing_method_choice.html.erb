<%# locals: (contract:, recipient: nil, bundle_id: nil) %>

<% signature_apps_qscd = params[:qscd].presence || current_user&.qscd || cookies[:qscd] %>
<% signature_field_appearance_required = contract.prepared_signature_field_appearance_required_for?(recipient: recipient) %>
<% can_render_signature_apps_in_frame = !signature_field_appearance_required && bundle_id.present? && (params[:iframe] == 'no_onboarding' || (signature_apps_qscd.present? && !User.legacy_eid_card?(signature_apps_qscd))) %>
<% electronic_signature_apps_path = if signature_field_appearance_required
  visual_signing_contract_path(contract, recipient: recipient&.uuid, iframe: params[:iframe], purpose: 'signature_field_appearance')
elsif can_render_signature_apps_in_frame
  signature_apps_contract_path(contract, recipient: recipient&.uuid, iframe: params[:iframe], embedded: true, qscd: signature_apps_qscd.presence)
else
  signature_apps_contract_path(contract, recipient: recipient&.uuid, iframe: params[:iframe], qscd: signature_apps_qscd.presence)
end %>

<%= turbo_frame_tag "signing_method_choice_#{contract.uuid}" do %>
  <div data-controller="signing-method" class="w-full space-y-4">
    <h3 class="text-lg font-semibold text-gray-900"><%= t('.title') %></h3>
    <div class="space-y-3">
      <% if contract.allowed_methods.include?('qes') %>
        <%= render 'shared/radio_button_card',
              name: "signing_method_#{contract.uuid}",
              value: 'electronic',
              label: t('.electronic_label'),
              description: t('.electronic_description'),
              checked: true,
              icon: 'mobile',
              data_attributes: {
                signing_method_target: 'methodRadio',
                action: 'change->signing-method#handleMethodSelection'
              } %>
      <% end %>

      <% if AdesEvidenceSession.available?(contract, recipient: recipient) %>
        <%= render 'shared/radio_button_card',
              name: "signing_method_#{contract.uuid}",
              value: 'ades',
              label: t('.ades_label'),
              description: t('.ades_description'),
              checked: !contract.allowed_methods.include?('qes') && !contract.allowed_methods.include?('scan') && !contract.allowed_methods.include?('visual'),
              icon: 'mobile',
              data_attributes: {
                signing_method_target: 'methodRadio',
                action: 'change->signing-method#handleMethodSelection'
              } %>
      <% end %>

      <% if contract.allowed_methods.include?('scan') %>
        <%= render 'shared/radio_button_card',
              name: "signing_method_#{contract.uuid}",
              value: 'physical',
              label: t('.physical_label'),
              description: t('.physical_description'),
              checked: false,
              icon: 'pencil',
              data_attributes: {
                signing_method_target: 'methodRadio',
                action: 'change->signing-method#handleMethodSelection'
              } %>
      <% end %>

      <% if contract.allowed_methods.include?('visual') && contract.visual_signing_allowed? %>
        <%= render 'shared/radio_button_card',
              name: "signing_method_#{contract.uuid}",
              value: 'visual',
              label: t('.visual_label'),
              description: t('.visual_description'),
              checked: !contract.allowed_methods.include?('qes') && !contract.allowed_methods.include?('scan'),
              icon: 'pencil',
              data_attributes: {
                signing_method_target: 'methodRadio',
                action: 'change->signing-method#handleMethodSelection'
              } %>
      <% end %>
    </div>

    <div class="hidden">
      <% if contract.allowed_methods.include?('qes') %>
        <%= link_to "",
            electronic_signature_apps_path,
            data: {
              signing_method_target: 'electronicButton',
              turbo_frame: (can_render_signature_apps_in_frame ? "signature_apps_#{contract.uuid}" : "_top")
            } %>
      <% end %>

      <% if AdesEvidenceSession.available?(contract, recipient: recipient) %>
        <%= link_to "",
            ades_contract_sessions_path(contract, recipient: recipient&.uuid, iframe: params[:iframe]),
            data: { signing_method_target: 'adesButton', turbo_frame: "_top" } %>
      <% end %>

      <% if contract.allowed_methods.include?('scan') %>
        <%= link_to "",
            physical_signing_contract_path(contract, recipient: recipient&.uuid, iframe: params[:iframe]),
            data: { signing_method_target: 'physicalButton', turbo_frame: "_top" } %>
      <% end %>

      <% if contract.allowed_methods.include?('visual') && contract.visual_signing_allowed? %>
        <%= link_to "",
            visual_signing_contract_path(contract, recipient: recipient&.uuid, iframe: params[:iframe]),
            data: { signing_method_target: 'visualButton', turbo_frame: "_top" } %>
      <% end %>
    </div>

    <div class="flex justify-end">
      <button type="button"
              data-signing-method-target="continueButton"
              data-action="click->signing-method#continue"
              class="px-4 py-2 bg-blue-600 text-white rounded-md cursor-pointer hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500">
        <%= t('.continue') %>
      </button>
    </div>
  </div>
<% end %>
