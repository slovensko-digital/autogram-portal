<main class="mx-auto max-w-3xl">
  <div class="relative isolate overflow-hidden">
    <%= turbo_frame_tag "signature_apps_#{@contract.uuid}",
      class: "mx-auto flex flex-col items-center max-w-4xl space-y-6 px-6 pb-8 pt-10 lg:flex lg:px-8" do %>
      <div class="w-full">
        <h1 class="text-3xl font-bold text-gray-900 mb-2"><%= t('.title') %></h1>
        <p class="text-gray-600"><%= t('.subtitle') %></p>
      </div>

      <div class="w-full" data-controller="signing-app-selector">
        <% if @eid_card_generation.present? && !User.supports_mobile_signing?(@eid_card_generation) %>
          <div data-signing-app-selector-target="yellowWarning">
            <%= render 'shared/warning', title: t('common.important'), content: t('.old_card_warning', generation: @eid_card_generation) %>
          </div>
        <% end %>

        <% if @eid_card_generation.present? && !User.supports_mobile_signing?(@eid_card_generation) %>
          <div data-signing-app-selector-target="mobileWarning" style="display: none;">
            <%= render 'shared/error', title: t('common.desktop_required'), content: t('.old_card_mobile_warning', generation: @eid_card_generation) %>
          </div>
        <% end %>

        <div class="space-y-3 mb-8">
          <div data-signing-app-selector-target="desktopElement">
            <%= render 'shared/radio_button_card',
                  name: "signing_app_#{@contract.uuid}",
                  value: 'autogram',
                  label: t('.autogram_desktop_label'),
                  description: t('.autogram_desktop_description'),
                  checked: true,
                  icon: 'desktop',
                  wrapper_class: 'desktop-signing-element',
                  data_attributes: {
                    signing_app_selector_target: 'appRadio'
                  } %>
          </div>

          <% unless @eid_card_generation.present? && !User.supports_mobile_signing?(@eid_card_generation) %>
            <%= render 'shared/radio_button_card',
                  name: "signing_app_#{@contract.uuid}",
                  value: 'avm',
                  label: t('.autogram_mobile_label'),
                  description: t('.autogram_mobile_description'),
                  checked: false,
                  icon: 'mobile',
                  data_attributes: {
                    signing_app_selector_target: 'appRadio'
                  } %>

            <%= render 'shared/radio_button_card',
                  name: "signing_app_#{@contract.uuid}",
                  value: 'eidentita',
                  label: t('.eidentita_label'),
                  description: t('.eidentita_description'),
                  checked: false,
                  icon: 'mobile',
                  data_attributes: {
                    signing_app_selector_target: 'appRadio'
                  } %>
          <% end %>
        </div>

        <div class="hidden">
          <%= link_to "", autogram_contract_sessions_path(@contract, recipient: @recipient, iframe: params[:iframe]),
                data: {
                  turbo_frame: "signature_apps_#{@contract.uuid}",
                  signing_app_selector_target: 'autogramSubmitButton'
                } %>

          <%= link_to "", avm_contract_sessions_path(@contract, recipient: @recipient, iframe: params[:iframe]),
                data: {
                  controller: "signers--avm",
                  action: "click->signers--avm#sign",
                  turbo_frame: "signature_apps_#{@contract.uuid}",
                  signing_app_selector_target: "avmSubmitButton"
                } %>

          <%= link_to "", eidentita_contract_sessions_path(@contract, recipient: @recipient, iframe: params[:iframe]),
                data: {
                  controller: "signers--eidentita",
                  action: "click->signers--eidentita#sign",
                  turbo_frame: "signature_apps_#{@contract.uuid}",
                  signing_app_selector_target: "eidentitaSubmitButton"
                } %>
        </div>

        <%= render 'shared/info',
          title: t('.first_time_signing'),
          content: t('.learn_more_text'),
          button: t('.how_signing_works'),
          target: contract_onboarding_path(@contract, 'eid_card_generation', method: 'electronic', review: 'true', recipient: @recipient&.uuid, iframe: params[:iframe]),
          blank: false
        %>

        <div class="border-b border-gray-200 my-8"></div>

        <div class="flex gap-8">
          <%
            back_path = if @contract.bundle
              sign_bundle_path(@contract.bundle, recipient: @recipient&.uuid, iframe: params[:iframe])
            else
              sign_contract_path(@contract, recipient: @recipient&.uuid, iframe: params[:iframe])
            end
          %>
          <%= link_to t('actions.back'),
            back_path,
            data: { turbo: false },
            class: "flex-1 inline-flex items-center justify-center px-6 py-2 text-base font-medium text-gray-700 bg-white border border-gray-300 rounded-md hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-blue-500"
          %>

          <button type="button"
                  data-signing-app-selector-target="signButton"
                  data-action="click->signing-app-selector#triggerSign"
                  class="flex-1 inline-flex justify-center items-center px-6 py-3 border border-transparent text-base font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 cursor-pointer focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500">
            <%= t('.continue_to_sign') %>
          </button>
        </div>
      <% end %>
    </div>
  </main>
