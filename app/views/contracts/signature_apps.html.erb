<% embedded = params[:embedded].present? %>
<% skip_method_choice = params[:skip_method_choice].present? %>

<%= turbo_frame_tag "signature_apps_#{@contract.uuid}" do %>
  <%=  turbo_stream_from @contract %>
  <% if embedded %>
    <div class="space-y-5" data-controller="signing-app-selector">
      <div class="w-full space-y-1">
        <h3 class="text-lg font-semibold text-gray-900"><%= t('.title') %></h3>
        <p class="text-sm text-gray-600"><%= t('.subtitle') %></p>
      </div>

      <% if @qscd.present? %>
        <%= link_to contract_onboarding_path(@contract, 'qscd_check', method: 'electronic', review: 'true', recipient: @recipient&.uuid, iframe: params[:iframe]), data: {turbo: false},
          class: "group block rounded-lg border border-blue-600 bg-white p-2 transition-all hover:border-blue-700 hover:bg-blue-50" do %>
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-6">
              <div class="flex-shrink-0">
                <%= image_tag "qscd/#{@qscd}.png", alt: t('.selected_card_generation', generation: @qscd), class: "h-24 w-auto rounded-md" %>
              </div>
              <div>
                <div class="text-sm font-medium text-gray-900"><%= t("qscd.title.#{@qscd}") %></div>
                <div class="mt-1 text-xs text-gray-500"><%= t('actions.change_selection') %></div>
              </div>
            </div>
            <div class="flex-shrink-0">
              <svg class="mx-4 h-6 w-6 text-blue-600 transition-colors group-hover:text-blue-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
              </svg>
            </div>
          </div>
        <% end %>
      <% end %>

      <% unless Session.old_card?(@qscd) %>
        <div data-signing-app-selector-target="yellowWarning">
          <%= render 'shared/warning', title: t('.old_card_warning_title'), content: t('.old_card_warning', qscd: t("qscd.title.#{@qscd}")) %>
        </div>

        <div data-signing-app-selector-target="mobileWarning" style="display: none;">
          <%= render 'shared/error', title: t('common.desktop_required'), content: t('.old_card_mobile_warning', qscd: t("qscd.title.#{@qscd}")) %>
        </div>
      <% end %>

      <div class="space-y-3">
        <div data-signing-app-selector-target="desktopElement">
          <% if AutogramSession.available?(@qscd, @contract) %>
            <%= render 'shared/radio_button_card',
                  name: "signing_app_#{@contract.uuid}",
                  value: 'autogram',
                  label: t('.autogram_desktop_label'),
                  description: t('.autogram_desktop_description'),
                  checked: true,
                  icon: 'desktop',
                  wrapper_class: 'desktop-signing-element',
                  data_attributes: {
                    signing_app_selector_target: 'appRadio'
                  } %>
          <% end %>
        </div>

        <% if AvmSession.available?(@qscd, @contract) %>
          <%= render 'shared/radio_button_card',
                name: "signing_app_#{@contract.uuid}",
                value: 'avm',
                label: t('.autogram_mobile_label'),
                description: t('.autogram_mobile_description'),
                checked: false,
                icon: 'mobile',
                data_attributes: {
                  signing_app_selector_target: 'appRadio'
                } %>
        <% end %>

        <% if EidentitaSession.available?(@qscd, @contract) %>
          <%= render 'shared/radio_button_card',
                name: "signing_app_#{@contract.uuid}",
                value: 'eidentita',
                label: t('.eidentita_label'),
                description: t('.eidentita_description'),
                checked: false,
                icon: 'mobile',
                data_attributes: {
                  signing_app_selector_target: 'appRadio'
                } %>

          <% unless params[:iframe] %>
            <%= render 'shared/info',
                  title: t('.third_party_notice_title'),
                  content: t('.third_party_notice') %>
          <% end %>
        <% end %>
      </div>

      <div class="hidden">
        <% if AutogramSession.available?(@qscd, @contract) %>
          <%= link_to "", autogram_contract_sessions_path(@contract, recipient: @recipient, iframe: params[:iframe], embedded: params[:embedded], skip_method_choice: params[:skip_method_choice]),
                data: {
                  turbo_frame: "signature_apps_#{@contract.uuid}",
                  signing_app_selector_target: 'autogramSubmitButton'
                } %>
        <% end %>

        <% if AvmSession.available?(@qscd, @contract) %>
          <%= link_to "", avm_contract_sessions_path(@contract, recipient: @recipient, iframe: params[:iframe], embedded: params[:embedded], skip_method_choice: params[:skip_method_choice]),
                data: {
                  turbo_frame: "signature_apps_#{@contract.uuid}",
                  signing_app_selector_target: "avmSubmitButton"
                } %>
        <% end %>

        <% if EidentitaSession.available?(@qscd, @contract) %>
          <%= link_to "", eidentita_contract_sessions_path(@contract, recipient: @recipient, iframe: params[:iframe], embedded: params[:embedded], skip_method_choice: params[:skip_method_choice]),
                data: {
                  turbo_frame: "signature_apps_#{@contract.uuid}",
                  signing_app_selector_target: "eidentitaSubmitButton"
                } %>
        <% end %>
      </div>

      <div class="flex flex-col-reverse gap-3 sm:flex-row sm:gap-4">
        <%
          back_path = if @contract.bundle
            sign_bundle_path(@contract.bundle, recipient: @recipient&.uuid, iframe: params[:iframe], embedded: params[:embedded], skip_method_choice: params[:skip_method_choice])
          else
            sign_contract_path(@contract, recipient: @recipient&.uuid, iframe: params[:iframe], embedded: params[:embedded], skip_method_choice: params[:skip_method_choice])
          end
        %>
        <% unless skip_method_choice %>
          <%= link_to t('actions.back'),
            back_path,
            data: { turbo: false },
            class: "inline-flex items-center justify-center rounded-md border border-gray-300 bg-white px-6 py-2 text-base font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-blue-500 sm:flex-1"
          %>
        <% end %>

        <button type="button"
                data-signing-app-selector-target="signButton"
                data-action="click->signing-app-selector#triggerSign"
                class="inline-flex items-center justify-center rounded-md border border-transparent bg-blue-600 px-4 py-2 text-base font-medium text-white hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 <%= skip_method_choice ? 'w-full' : 'sm:flex-1' %>">
          <%= t('.continue_to_sign') %>
        </button>
      </div>
    </div>
  <% else %>
    <main class="mx-auto flex max-w-4xl flex-col items-center space-y-6 lg:flex">
      <div class="relative isolate overflow-hidden">
        <div class="w-full space-y-8 p-6" data-controller="signing-app-selector">
          <div class="mb-4 w-full">
            <h1 class="mb-2 text-3xl font-bold text-gray-900"><%= t('.title') %></h1>
            <p class="text-gray-600"><%= t('.subtitle') %></p>
          </div>

          <% if @qscd.present? %>
            <%= link_to contract_onboarding_path(@contract, 'qscd_check', method: 'electronic', review: 'true', recipient: @recipient&.uuid, iframe: params[:iframe]), data: {turbo: false},
              class: "group block cursor-pointer rounded-lg border border-blue-600 bg-white p-2 transition-all hover:border-blue-700 hover:bg-blue-50" do %>
              <div class="flex items-center justify-between">
                <div class="flex items-center gap-6">
                  <div class="flex-shrink-0">
                    <%= image_tag "qscd/#{@qscd}.png", alt: t('.selected_card_generation', generation: @qscd), class: "h-24 w-auto rounded-md" %>
                  </div>
                  <div>
                    <div class="text-sm font-medium text-gray-900"><%= t("qscd.title.#{@qscd}") %></div>
                    <div class="mt-1 text-xs text-gray-500"><%= t('actions.change_selection') %></div>
                  </div>
                </div>
                <div class="flex-shrink-0">
                  <svg class="mx-4 h-6 w-6 text-blue-600 transition-colors group-hover:text-blue-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
                  </svg>
                </div>
              </div>
            <% end %>
          <% end %>

          <% if Session.old_card?(@qscd) %>
            <div data-signing-app-selector-target="yellowWarning">
              <%= render 'shared/warning', title: t('.old_card_warning_title'), content: t('.old_card_warning', qscd: t("qscd.title.#{@qscd}")) %>
            </div>

            <div data-signing-app-selector-target="mobileWarning" style="display: none;">
              <%= render 'shared/error', title: t('common.desktop_required'), content: t('.old_card_mobile_warning', qscd: t("qscd.title.#{@qscd}")) %>
            </div>
          <% end %>

          <% if Session.multiple_files?(@contract) %>
            <div data-signing-app-selector-target="yellowWarning">
              <%= render 'shared/warning', title: t('.multiple_files_in_contract_warning_title'), content: t('.multiple_files_in_contract_warning') %>
            </div>

            <div data-signing-app-selector-target="mobileWarning" style="display: none;">
              <%= render 'shared/error', title: t('common.desktop_required'), content: t('.multiple_files_in_contract_mobile_warning') %>
            </div>
          <% end %>

          <div class="space-y-3">
            <div data-signing-app-selector-target="desktopElement">
              <% if AutogramSession.available?(@qscd, @contract) %>
                <%= render 'shared/radio_button_card',
                      name: "signing_app_#{@contract.uuid}",
                      value: 'autogram',
                      label: t('.autogram_desktop_label'),
                      description: t('.autogram_desktop_description'),
                      checked: true,
                      icon: 'desktop',
                      wrapper_class: 'desktop-signing-element',
                      data_attributes: {
                        signing_app_selector_target: 'appRadio'
                      } %>
              <% end %>
            </div>

            <% if AvmSession.available?(@qscd, @contract) %>
              <%= render 'shared/radio_button_card',
                    name: "signing_app_#{@contract.uuid}",
                    value: 'avm',
                    label: t('.autogram_mobile_label'),
                    description: t('.autogram_mobile_description'),
                    checked: false,
                    icon: 'mobile',
                    data_attributes: {
                      signing_app_selector_target: 'appRadio'
                    } %>
            <% end %>

            <% if EidentitaSession.available?(@qscd, @contract) %>
              <%= render 'shared/radio_button_card',
                    name: "signing_app_#{@contract.uuid}",
                    value: 'eidentita',
                    label: t('.eidentita_label'),
                    description: t('.eidentita_description'),
                    checked: false,
                    icon: 'mobile',
                    data_attributes: {
                      signing_app_selector_target: 'appRadio'
                    } %>

              <% unless params[:iframe] %>
                <%= render 'shared/info',
                      title: t('.third_party_notice_title'),
                      content: t('.third_party_notice') %>
              <% end %>
            <% end %>
          </div>

          <div class="hidden">
            <% if AutogramSession.available?(@qscd, @contract) %>
              <%= link_to "", autogram_contract_sessions_path(@contract, recipient: @recipient, iframe: params[:iframe]),
                    data: {
                      turbo_frame: "signature_apps_#{@contract.uuid}",
                      signing_app_selector_target: 'autogramSubmitButton'
                    } %>
            <% end %>

            <% if AvmSession.available?(@qscd, @contract) %>
              <%= link_to "", avm_contract_sessions_path(@contract, recipient: @recipient, iframe: params[:iframe]),
                    data: {
                      turbo_frame: "signature_apps_#{@contract.uuid}",
                      signing_app_selector_target: "avmSubmitButton"
                    } %>
            <% end %>

            <% if EidentitaSession.available?(@qscd, @contract) %>
              <%= link_to "", eidentita_contract_sessions_path(@contract, recipient: @recipient, iframe: params[:iframe]),
                    data: {
                      turbo_frame: "signature_apps_#{@contract.uuid}",
                      signing_app_selector_target: "eidentitaSubmitButton"
                    } %>
            <% end %>
          </div>

          <div class="border-b border-gray-200"></div>

          <div class="flex gap-8">
            <%
              back_path = if @contract.bundle
                sign_bundle_path(@contract.bundle, recipient: @recipient&.uuid, iframe: params[:iframe])
              else
                sign_contract_path(@contract, recipient: @recipient&.uuid, iframe: params[:iframe])
              end
            %>
            <%= link_to t('actions.back'),
              back_path,
              data: { turbo: false },
              class: "flex-1 inline-flex items-center justify-center rounded-md border border-gray-300 bg-white px-6 py-2 text-base font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-blue-500"
            %>

            <button type="button"
                    data-signing-app-selector-target="signButton"
                    data-action="click->signing-app-selector#triggerSign"
                    class="flex-1 inline-flex justify-center items-center rounded-md border border-transparent bg-blue-600 px-4 py-2 text-base font-medium text-white hover:bg-blue-700 cursor-pointer focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2">
              <%= t('.continue_to_sign') %>
            </button>
          </div>
        </div>
      </div>
    </main>
  <% end %>
<% end %>
