<%= turbo_frame_tag frame_id do %>
  <div class="rounded-xl border border-amber-200 bg-amber-50 p-5">
    <h3 class="text-lg font-semibold text-amber-900"><%= t('contracts.signature_field_appearance_required.title') %></h3>
    <p class="mt-1 text-sm text-amber-800"><%= t('contracts.signature_field_appearance_required.description') %></p>
    <%= link_to t('contracts.signature_field_appearance_required.action'),
        visual_signing_contract_path(contract, recipient: recipient&.uuid, iframe: params[:iframe], purpose: 'signature_field_appearance'),
        class: "mt-4 inline-flex items-center justify-center rounded-md bg-amber-600 px-4 py-2 text-sm font-semibold text-white hover:bg-amber-700",
        data: { turbo_frame: "_top" } %>
  </div>
<% end %>