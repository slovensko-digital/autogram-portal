<p class="greeting"><%= t('notification_mailer.greeting') %></p>

<div class="section-card">
  <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="border-collapse: collapse;">
    <tr>
      <td width="56" valign="top" style="padding: 0 12px 10px 0;">
        <div class="section-icon"><%= render 'icon_document' %></div>
      </td>
      <td valign="middle" style="padding: 0 0 10px 0;">
        <h2 class="section-title" style="margin: 0;"><%= t('.title') %></h2>
      </td>
    </tr>
  </table>
  <p><%= t('.message', author_name: @bundle.author.display_name) %></p>
  <p><%= t('.signing_is_simple') %></p>
</div>

<% if @bundle.note.present? %>
<div class="section-card">
  <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="border-collapse: collapse;">
    <tr>
      <td width="56" valign="top" style="padding: 0 12px 10px 0;">
        <div class="section-icon"><%= render 'icon_document' %></div>
      </td>
      <td valign="middle" style="padding: 0 0 10px 0;">
        <h3 class="section-title" style="margin: 0;"><%= t('.note_from_sender_title') %></h3>
      </td>
    </tr>
  </table>
  <p><%= @bundle.note.gsub("\n", "<br>").html_safe %></p>
</div>
<% end %>

<div class="section-card">
  <p style="font-size: 14px; font-weight: 600; letter-spacing: 0.07em; color: #9CA3AF; text-transform: uppercase; margin: 0 0 10px;"><%= t('.documents') %></p>
  <% @bundle.contracts.each do |contract| %>
    <p><%= contract.display_name %></p>
  <% end %>
</div>

<%= link_to t('.view_bundle'), sign_bundle_url(@bundle, recipient: @user), class: "button", target: "_blank" %>

<div style="height:1px;background-color:#E5E7EB;margin:24px 0;"></div>

<div style="margin: 32px 0 20px;">
  <h3 style="font-size: 18px; font-weight: 700; color: #111827; margin: 0 0 20px; text-align: center;"><%= t('.how_it_works_title') %></h3>
  <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="border-collapse: collapse; table-layout: fixed;">
    <tr>
      <td width="33.33%" valign="top" align="center" style="padding: 0 6px;">
        <div style="width: 48px; height: 48px; line-height: 48px; text-align: center; background: #3B82F6; color: #ffffff; border-radius: 12px; font-size: 20px; font-weight: 700; margin: 0 auto 10px;">1</div>
        <p style="font-size: 14px; font-weight: 700; color: #111827; line-height: 1.3; margin: 0 0 4px;"><%= t('.step_1_title') %></p>
        <p style="font-size: 14px; color: #6B7280; line-height: 1.5; margin: 0;"><%= t('.step_1_desc') %></p>
      </td>
      <td width="33.33%" valign="top" align="center" style="padding: 0 6px;">
        <div style="width: 48px; height: 48px; line-height: 48px; text-align: center; background: #3B82F6; color: #ffffff; border-radius: 12px; font-size: 20px; font-weight: 700; margin: 0 auto 10px;">2</div>
        <p style="font-size: 14px; font-weight: 700; color: #111827; line-height: 1.3; margin: 0 0 4px;"><%= t('.step_2_title') %></p>
        <p style="font-size: 14px; color: #6B7280; line-height: 1.5; margin: 0;"><%= t('.step_2_desc') %></p>
      </td>
      <td width="33.33%" valign="top" align="center" style="padding: 0 6px;">
        <div style="width: 48px; height: 48px; line-height: 48px; text-align: center; background: #10B981; color: #ffffff; border-radius: 12px; font-size: 20px; font-weight: 700; margin: 0 auto 10px;">✓</div>
        <p style="font-size: 14px; font-weight: 700; color: #111827; line-height: 1.3; margin: 0 0 4px;"><%= t('.step_3_title') %></p>
        <p style="font-size: 14px; color: #6B7280; line-height: 1.5; margin: 0;"><%= t('.step_3_desc') %></p>
      </td>
    </tr>
  </table>
</div>
