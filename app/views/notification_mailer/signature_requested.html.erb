<p class="greeting"><%= t('.greeting') %> 👋</p>

<%# Card 1: Main request %>
<div class="section-card">
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom:14px;">
    <tr>
      <td width="56" valign="middle">
        <div class="section-icon"><%= render 'icon_document' %></div>
      </td>
      <td valign="middle">
        <h2 class="section-title"><%= t('.title') %></h2>
      </td>
    </tr>
  </table>
  <p class="section-body"><%= t('.sender_message', sender_name: @bundle.author.name) %></p>
  <p class="warning-text">&#9888; <%= t('.verify_sender_warning') %></p>
</div>

<%# Card 2: Note from sender (if present) %>
<% if @bundle.note.present? %>
<div class="section-card">
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom:14px;">
    <tr>
      <td width="56" valign="middle">
        <div class="section-icon"><%= render 'icon_document' %></div>
      </td>
      <td valign="middle">
        <h3 class="section-title"><%= t('.note_from_sender_title') %></h3>
      </td>
    </tr>
  </table>
  <p class="note-body"><%= @bundle.note.gsub("\n", "<br>").html_safe %></p>
  <p class="note-author">&mdash; <%= @bundle.author.name %></p>
</div>
<% end %>

<%# Card 3: Documents %>
<div class="section-card">
  <p class="doc-label"><%= t('.document_name_label') %></p>
  <% @bundle.contracts.each do |contract| %>
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom:6px;">
    <tr>
      <td width="46" valign="middle">
        <div class="doc-icon"><%= render 'icon_document_sm' %></div>
      </td>
      <td valign="middle" style="font-size:14px;color:#374151;">
        <%= contract.display_name %>
      </td>
    </tr>
  </table>
  <% end %>
</div>

<%# CTA Button %>
<%= link_to t('.view_bundle'), sign_bundle_url(@bundle, recipient: @user), class: "button", target: "_blank" %>

<%# How it works %>
<div class="steps-section">
  <h3 class="steps-heading"><%= t('.how_it_works_title') %></h3>
  <table class="steps-table" role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
    <tr>
      <td class="step-cell" align="center">
        <div class="step-bubble">1</div>
        <p class="step-title"><%= t('.step_1_title') %></p>
        <p class="step-desc"><%= t('.step_1_desc') %></p>
      </td>
      <td class="step-cell" align="center">
        <div class="step-bubble">2</div>
        <p class="step-title"><%= t('.step_2_title') %></p>
        <p class="step-desc"><%= t('.step_2_desc') %></p>
      </td>
      <td class="step-cell" align="center">
        <div class="step-bubble-done">&#10003;</div>
        <p class="step-title"><%= t('.step_3_title') %></p>
        <p class="step-desc"><%= t('.step_3_desc') %></p>
      </td>
    </tr>
  </table>
</div>

<%# Legal validity %>
<div class="legal-box">
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom:10px;">
    <tr>
      <td width="38" valign="middle">
        <div class="legal-check-circle"><%= render 'icon_legal_check' %></div>
      </td>
      <td valign="middle">
        <p class="legal-title"><%= t('.legal_validity_title') %></p>
      </td>
    </tr>
  </table>
  <p class="legal-body"><%= t('.legal_validity_text') %></p>
  <p style="margin:0;">
    <span class="pill-tag">&#10003; <%= t('.tag_qualified_signature') %></span>
    <span class="pill-tag">&#10003; <%= t('.tag_timestamp') %></span>
    <span class="pill-tag">&#10003; <%= t('.tag_ca_certificate') %></span>
  </p>
</div>

<%= render "footer" %>
