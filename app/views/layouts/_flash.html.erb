<% if flash.any? %>
  <div class="mx-auto max-w-4xl px-6 py-4">
    <% flash.each do |type, message| %>
      <% if type == 'notice' %>
        <div class="bg-green-50 border border-green-200 rounded-lg p-4 relative" role="alert" data-controller="flash">
          <div class="flex items-start">
            <div class="flex-shrink-0">
              <svg class="h-5 w-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <div class="ml-3 flex-1">
              <p class="text-sm text-green-800">
                <%= message %>
              </p>
            </div>
            <button type="button"
                    class="ml-3 inline-flex rounded-md p-1 text-green-700 hover:bg-green-100 focus:outline-none focus:ring-2 focus:ring-green-600 cursor-pointer"
                    data-action="click->flash#close"
                    aria-label="<%= t('actions.close') %>">
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
              </svg>
            </button>
          </div>
        </div>
      <% elsif type == 'alert' %>
        <div class="bg-red-50 border border-red-200 rounded-lg p-4 relative" role="alert" data-controller="flash">
          <div class="flex items-start">
            <div class="flex-shrink-0">
              <svg class="h-5 w-5 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
              </svg>
            </div>
            <div class="ml-3 flex-1">
              <p class="text-sm text-red-800">
                <%= message %>
              </p>
            </div>
            <button type="button"
                    class="ml-3 inline-flex rounded-md p-1 text-red-700 hover:bg-red-100 focus:outline-none focus:ring-2 focus:ring-red-600 cursor-pointer"
                    data-action="click->flash#close"
                    aria-label="<%= t('actions.close') %>">
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
              </svg>
            </button>
          </div>
        </div>
      <% else %>
        <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 relative" role="alert" data-controller="flash">
          <div class="flex items-start">
            <div class="flex-shrink-0">
              <svg class="h-5 w-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <div class="ml-3 flex-1">
              <p class="text-sm text-blue-800">
                <%= message %>
              </p>
            </div>
            <button type="button"
                    class="ml-3 inline-flex rounded-md p-1 text-blue-700 hover:bg-blue-100 focus:outline-none focus:ring-2 focus:ring-blue-600 cursor-pointer"
                    data-action="click->flash#close"
                    aria-label="<%= t('actions.close') %>">
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
              </svg>
            </button>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>
<% end %>
