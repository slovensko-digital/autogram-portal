<!DOCTYPE html>
<html>
  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
      body {
        margin: 1em;
        padding: 0;
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Arial, sans-serif;
        background-color: #F9FAFB;
      }
      p {
        font-size: 16px;
        line-height: 1.6;
        color: #374151;
        margin: 0 0 16px;
      }
      .email-container {
        max-width: 600px;
        margin: 0 auto;
        background-color: #ffffff;
        border: 1px solid #E5E7EB;
        border-radius: 12px;
        overflow: hidden;
      }
      .top-bar {
        height: 4px;
        background: linear-gradient(to right, #51A2FF, #155DFC, #9810FA);
        font-size: 0;
        line-height: 0;
      }
      .header {
        padding: 2em;
        text-align: center;
        background-color: #ffffff;
      }
      .logo-text {
        font-size: 26px;
        line-height: 1.2;
        color: #111827;
        text-decoration: none;
      }
      .logo-highlight {
        background: linear-gradient(to bottom, transparent 90%, #FDE047 10%);
        padding: 0 2px;
      }
      .body {
        padding: 2em;
        background-color: #ffffff;
        border-top: 1px solid #E5E7EB;
        border-bottom: 1px solid #E5E7EB;
      }
      .greeting {
        font-size: 16px;
        line-height: 1.5;
        color: #374151;
        margin: 0 0 16px;
      }
      /* Section cards */
      .section-card {
        background: #ffffff;
        border: 1px solid #E5E7EB;
        border-radius: 12px;
        padding: 1em 1em 0 1em;
        margin-bottom: 2em;
      }
      .section-icon {
        width: 44px;
        height: 44px;
        background-color: #EFF6FF;
        border-radius: 10px;
        padding: 11px;
        box-sizing: border-box;
      }
      .section-title {
        font-size: 18px;
        font-weight: 700;
        color: #111827;
        margin: 0;
        line-height: 1.4;
      }
      .section-body {
        font-size: 16px;
        color: #374151;
        line-height: 1.6;
      }
      /* Details list (used in signed notifications) */
      .details {
        margin: 0 0 0;
      }
      .details-title {
        font-weight: 600;
        font-size: 14px;
        letter-spacing: 0.07em;
        text-transform: uppercase;
        color: #9CA3AF;
        margin: 0 0 10px;
      }
      .details-list {
        margin-bottom: 1em;
        padding: 0;
        background-color: #F9FAFB;
        border-radius: 8px;
        overflow: hidden;
      }
      .details-list div {
        padding: 10px 14px;
        border-bottom: 1px solid #F3F4F6;
        color: #374151;
        font-size: 16px;
      }
      .details-list div:last-child {
        border-bottom: none;
      }
      /* CTA Button */
      .button {
        display: block;
        width: 100%;
        padding: 14px 24px;
        background-color: #165EFC;
        color: #ffffff !important;
        text-align: center;
        text-decoration: none;
        border-radius: 8px;
        font-size: 16px;
        font-weight: 600;
        line-height: 1.5;
        margin: 20px 0;
        box-sizing: border-box;
      }
      a.button { color: #ffffff !important; }
      a.button:link, a.button:visited, a.button:hover, a.button:active {
        color: #ffffff !important;
        text-decoration: none !important;
      }
      /* Footer block (inside body, above bottom footer) */
      .footer-block {
        text-align: center;
        padding: 2em;
      }
      .footer-regards-text {
        font-size: 16px;
        color: #6B7280;
        margin: 0 0 2px;
        line-height: 1.5;
      }
      .footer-brand {
        font-size: 16px;
        font-weight: 700;
        color: #111827;
        margin: 0 0 4px;
        line-height: 1.5;
      }
      .footer-provider {
        font-size: 14px;
        color: #9CA3AF;
        margin: 0;
      }
    </style>
  </head>

  <body>
    <div class="email-container">
      <div class="top-bar">&nbsp;</div>

      <div class="header">
        <span class="logo-text logo-highlight"><span style="font-weight: 700;">Autogram</span> Portal</span>
      </div>

      <div class="body">
        <%= yield %>
      </div>

      <div class="footer-block">
        <p class="footer-regards-text"><%= t('.regards') %></p>
        <p class="footer-brand"><%= t('.team') %></p>
      </div>
    </div>
  </body>
</html>
