<main>
  <div class="relative isolate overflow-hidden">
    <div class="mx-auto max-w-7xl px-6 pb-24 pt-10 sm:pb-40 lg:px-8">
        <div class="mb-8">
          <h1 class="text-3xl font-bold text-gray-900 mb-2"><%= t('.title', resource: devise_i18n_fix_model_name_case(resource.model_name.human, i18n_key: 'registrations.edit.title')) %></h1>
          <p class="text-gray-600"><%= t('.subtitle') %></p>
        </div>

        <div class="bg-white sm:rounded-md border border-gray-200">
          <div class="px-4 py-5 sm:p-6">
            <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, class: "space-y-6" }) do |f| %>
              <%= render "devise/shared/error_messages", resource: resource %>

              <div>
                <%= f.label :name, t('.name'), class: "block text-sm font-medium text-gray-700 mb-2" %>
                <%= f.text_field :name, autocomplete: "name",
                  class: "block w-full rounded-md border-gray-300  focus:border-blue-500 focus:ring-blue-500 sm:text-sm py-2 px-3 border" %>
              </div>

              <div>
                <%= f.label :email, t('.email'), class: "block text-sm font-medium text-gray-700 mb-2" %>
                <%= f.email_field :email, readonly: true,
                  class: "block w-full rounded-md border-gray-300 bg-gray-50 sm:text-sm py-2 px-3 border text-gray-500 cursor-not-allowed" %>
              </div>

              <div>
                <%= f.label :api_token_public_key, t('.api_token_public_key'), class: "block text-sm font-medium text-gray-700 mb-2" %>
                <% if resource.feature_enabled? :api %>
                  <%= f.text_area :api_token_public_key, rows: 5,
                    class: "block w-full rounded-md border-gray-300 focus:border-blue-500 focus:ring-blue-500 sm:text-sm py-2 px-3 border" %>
                  <p class="mt-1 text-xs text-gray-500"><%= t('.api_token_help') %></p>
                <% else %>
                  <%= f.text_area :api_token_public_key, rows: 5, disabled: true,
                    class: "block w-full rounded-md border-gray-300 bg-gray-50 sm:text-sm py-2 px-3 border text-gray-500 cursor-not-allowed" %>
                  <p class="mt-1 text-xs text-gray-500"><%= t('.api_token_help') %></p>
                <% end %>
              </div>

              <% if resource.pending_reconfirmation? %>
                <div class="rounded-md bg-yellow-50 p-4">
                  <div class="flex">
                    <div class="flex-shrink-0">
                      <svg class="h-5 w-5 text-yellow-400" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
                      </svg>
                    </div>
                    <div class="ml-3">
                      <p class="text-sm text-yellow-700">
                        <%= t('.currently_waiting_confirmation_for_email', email: resource.unconfirmed_email) %>
                      </p>
                    </div>
                  </div>
                </div>
              <% end %>

              <div class="flex items-center justify-end gap-4">
                <%= f.submit t('.update'),
                  class: "w-full md:w-auto flex justify-center py-2 px-4 border border-transparent rounded-md text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors" %>
              </div>
            <% end %>
          </div>
        </div>

        <div class="mt-10 rounded-md border border-red-200 bg-white overflow-hidden">
          <div class="px-5 py-4 border-b border-red-100">
            <h3 class="text-xl font-semibold text-red-800"><%= t('.danger_zone') %></h3>
          </div>

          <div class="px-5 py-6" data-controller="delete-confirmation" data-delete-confirmation-phrase-value="<%= t('.delete_confirmation_phrase') %>">
            <h4 class="text-xl font-medium text-gray-900"><%= t('.cancel_my_account') %></h4>
            <p class="mt-1 text-md"><%= t('.unhappy') %></p>

            <%= form_with url: registration_path(resource_name), method: :delete, class: "mt-4" do %>
              <div class="flex flex-col gap-3 md:flex-row md:items-center">
                <%= text_field_tag :delete_confirmation,
                      nil,
                      class: "w-full md:max-w-md rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-red-500 focus:ring-red-500",
                      placeholder: t('.delete_confirmation_phrase'),
                      data: { delete_confirmation_target: "input", action: "input->delete-confirmation#update" } %>

                <%= submit_tag t('.delete_account'),
                      class: "inline-flex items-center justify-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-red-600 hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500 transition-colors",
                      data: { delete_confirmation_target: "submit" } %>
              </div>
            <% end %>
          </div>
        </div>
    </div>
  </div>
</main>

<% content_for :title, t('.title', resource: devise_i18n_fix_model_name_case(resource.model_name.human, i18n_key: 'registrations.edit.title')) %>
