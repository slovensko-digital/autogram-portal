<main>
  <div class="relative isolate overflow-hidden">
    <div class="mx-auto max-w-7xl px-6 pb-24 pt-10 sm:pb-40 lg:px-8">
      <div class="mx-auto max-w-md border border-gray-200 rounded-lg px-4 py-5 sm:p-6 bg-white">
        <div class="mb-8 text-center">
          <h1 class="text-3xl font-bold text-gray-900 mb-2"><%= t('.sign_up') %></h1>
          <p class="text-gray-600"><%= t('.subtitle') %></p>
        </div>

        <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-6" }) do |f| %>
          <%= render "devise/shared/error_messages", resource: resource %>

          <div>
            <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= f.email_field :email, autofocus: true, autocomplete: "email",
                class: "block w-full rounded-md border-gray-300  focus:border-blue-500 focus:ring-blue-500 sm:text-sm py-2 px-3 border" %>
          </div>

          <%= render "devise/shared/captcha" %>

          <label class="group relative flex items-center space-x-3 p-4 border border-gray-300 rounded-lg hover:border-blue-300 hover:bg-blue-50 transition-colors cursor-pointer has-[:focus]:ring-2 has-[:focus]:ring-blue-500 has-[:focus]:ring-offset-2">
            <%= f.check_box :agree_to_policies, { required: true, class: "sr-only" } %>
            <div class="flex-shrink-0">
              <div class="w-5 h-5 border border-gray-500 rounded flex items-center justify-center group-has-[:checked]:border-blue-500 group-has-[:checked]:bg-blue-500 transition-colors">
                <svg class="hidden group-has-[:checked]:block w-3.5 h-3.5 text-white" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
              </div>
            </div>
            <div class="flex-1">
              <div class="text-sm text-gray-800 mt-1">
                <%= t('upload_form.agree_to_policies_html',
                      terms_link: link_to(t('upload_form.terms_of_service'), terms_of_service_index_path, target: "_blank", class: "text-blue-600 underline"),
                      privacy_link: link_to(t('upload_form.privacy_policy'), privacy_policy_index_path, target: "_blank", class: "text-blue-600 underline")).html_safe %>
                <span class="text-red-500">*</span>
              </div>
            </div>
            <div class="hidden has-[:checked]:block absolute top-4 right-4">
              <svg class="h-5 w-5 text-blue-500" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
            </div>
          </label>

          <div>
            <%= f.submit t('.sign_up'),
                class: "w-full flex justify-center py-2 px-4 border border-transparent rounded-md  text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors" %>
          </div>

        <% end %>

        <div class="mt-6">
          <div class="relative mb-4">
            <div class="absolute inset-0 flex items-center">
              <div class="w-full border-t border-gray-300"></div>
            </div>
            <div class="relative flex justify-center text-sm">
              <span class="px-2 bg-white text-gray-500"><%= t('.or_continue_with') %></span>
            </div>
          </div>

          <%= form_with url: user_google_oauth2_omniauth_authorize_path, method: :post, data: { turbo: false } do %>
            <button type="submit" class="w-full flex items-center justify-center gap-3 py-2 px-4 border border-gray-300 rounded-md bg-white text-sm font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors">
              <svg class="h-5 w-5" viewBox="0 0 24 24">
                <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
                <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
              </svg>
              <%= t('.sign_up_with_google') %>
            </button>
          <% end %>
        </div>

        <div class="mt-4">
          <%= render "devise/shared/links" %>
        </div>
      </div>
    </div>
  </div>
</main>

<% content_for :title, t('.sign_up') %>
