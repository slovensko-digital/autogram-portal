<%# locals: (title:, content:, button: nil, target: nil) %>

<div class="bg-red-50 border border-red-300 rounded-lg p-4 mb-4">
  <div class="flex items-start">
    <div class="flex-shrink-0">
      <svg class="h-5 w-5 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
      </svg>
    </div>
    <div class="ml-3 flex-1">
      <h4 class="text-sm font-semibold text-red-900 mb-1"><%= title %></h4>
      <p class="text-sm text-red-800">
        <%= content %>
      </p>
      <% if button && target %>
        <p class="text-sm mt-4">
          <strong>
            <a href="<%= target %>" target="_blank" class="text-red-800 hover:text-red-500 underline"> <%= button %> </a>
          </strong>
        </p>
      <% end %>
    </div>
  </div>
</div>
