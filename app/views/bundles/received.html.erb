<main>
  <div class="mx-auto max-w-6xl px-6 pb-24 pt-10 lg:px-8">

    <%# Page header %>
    <div class="mb-6">
      <h1 class="text-3xl font-bold text-gray-900"><%= t('.title') %></h1>
      <p class="mt-1 text-sm text-gray-500"><%= t('.subtitle') %></p>
    </div>

    <%# Filter bar %>
    <%= form_with url: received_bundles_path, method: :get, local: true, class: "mb-5 flex flex-col sm:flex-row sm:items-center gap-3" do |f| %>
      <div class="flex items-center gap-2">
        <%= f.label :state, t('.filter_state'), class: "text-sm font-medium text-gray-700 whitespace-nowrap" %>
        <%= f.select :state,
              [[t('.state_all'), ""], [t('.state_awaiting'), "awaiting"], [t('.state_signed'), "signed"], [t('.state_declined'), "declined"], [t('.state_superseded'), "superseded"]],
              { selected: @state.to_s },
              class: "rounded-lg border border-gray-300 bg-white px-3 py-1.5 text-sm text-gray-700 focus:outline-none focus:ring-2 focus:ring-blue-500",
              onchange: "this.form.submit()" %>
      </div>
      <div class="flex items-center gap-2">
        <%= f.label :sort, t('.filter_sort'), class: "text-sm font-medium text-gray-700 whitespace-nowrap" %>
        <%= f.select :sort,
              [[t('.sort_newest'), "newest"], [t('.sort_oldest'), "oldest"]],
              { selected: @sort },
              class: "rounded-lg border border-gray-300 bg-white px-3 py-1.5 text-sm text-gray-700 focus:outline-none focus:ring-2 focus:ring-blue-500",
              onchange: "this.form.submit()" %>
      </div>
    <% end %>

    <% if @bundles.any? %>
      <div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
        <div class="divide-y divide-gray-100">
          <% @bundles.each do |bundle| %>
            <% recipient = @recipients_by_bundle[bundle.id] %>
            <% personally_signed = recipient&.signed? %>
            <% personally_superseded = recipient&.superseded? %>
            <div class="flex items-center gap-3 px-4 py-3.5 hover:bg-gray-50 transition-colors">
              <div class="h-9 w-9 rounded-lg bg-blue-50 flex items-center justify-center shrink-0">
                <svg class="h-5 w-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12.75V12A2.25 2.25 0 014.5 9.75h15A2.25 2.25 0 0121.75 12v.75m-8.69-6.44-2.12-2.12a1.5 1.5 0 00-1.061-.44H4.5A2.25 2.25 0 002.25 6v12a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9a2.25 2.25 0 00-2.25-2.25h-5.379a1.5 1.5 0 01-1.06-.44z" />
                </svg>
              </div>
              <div class="flex-1 min-w-0 space-y-1">
                <div class="flex items-center gap-2 flex-wrap">
                  <span class="text-sm font-semibold text-gray-900"><%= bundle.display_name %></span>
                </div>
                <div class="md:hidden">
                  <% if recipient&.declined? %>
                    <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
                      <span class="h-1.5 w-1.5 rounded-full bg-red-500 shrink-0"></span>
                      <%= t('.state_declined') %>
                    </span>
                  <% elsif personally_superseded %>
                    <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600">
                      <span class="h-1.5 w-1.5 rounded-full bg-gray-400 shrink-0"></span>
                      <%= t('.state_superseded') %>
                    </span>
                  <% elsif personally_signed %>
                    <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                      <span class="h-1.5 w-1.5 rounded-full bg-green-500 shrink-0"></span>
                      <%= t('.state_signed') %>
                    </span>
                  <% else %>
                    <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">
                      <span class="h-1.5 w-1.5 rounded-full bg-yellow-500 shrink-0"></span>
                      <%= t('.state_awaiting') %>
                    </span>
                  <% end %>
                </div>
                <div class="mt-0.5 flex items-center space-y-1 space-x-3 text-xs text-gray-400 flex-wrap">
                  <span class="flex items-center gap-1">
                    <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
                    </svg>
                    <%= bundle.author.display_name %>
                  </span>
                  <span class="flex items-center gap-1">
                    <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 9v7.5" />
                    </svg>
                    <%= bundle.created_at.strftime("%d.%m.%Y") %>
                  </span>
                </div>
              </div>
              <div class="hidden md:flex flex-1">
                <% if recipient&.declined? %>
                  <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
                    <span class="h-1.5 w-1.5 rounded-full bg-red-500 shrink-0"></span>
                    <%= t('.state_declined') %>
                  </span>
                <% elsif personally_superseded %>
                  <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600">
                    <span class="h-1.5 w-1.5 rounded-full bg-gray-400 shrink-0"></span>
                    <%= t('.state_superseded') %>
                  </span>
                <% elsif personally_signed %>
                  <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                    <span class="h-1.5 w-1.5 rounded-full bg-green-500 shrink-0"></span>
                    <%= t('.state_signed') %>
                  </span>
                <% else %>
                  <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">
                    <span class="h-1.5 w-1.5 rounded-full bg-yellow-500 shrink-0"></span>
                    <%= t('.state_awaiting') %>
                  </span>
                <% end %>
              </div>
              <div class="flex items-center gap-0.5 w-20 shrink-0 justify-end">
                <% if recipient && !personally_signed %>
                  <%= link_to t('actions.view'), sign_bundle_path(bundle, recipient: recipient.uuid),
                              class: "underline text-sm font-medium text-blue-600 hover:text-blue-700 transition-colors",
                              title: t('actions.view') %>
                <% else %>
                  <%= link_to t('actions.view'), sign_bundle_path(bundle, recipient: recipient&.uuid),
                              class: "underline text-sm font-medium text-blue-600 hover:text-blue-700 transition-colors",
                              title: t('actions.view') %>
                <% end %>
              </div>

            </div>
          <% end %>
        </div>
      </div>
    <% else %>
      <div class="bg-white rounded-lg border border-gray-200 text-center py-16">
        <svg class="mx-auto h-12 w-12 text-gray-300" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 13.5h3.86a2.25 2.25 0 012.012 1.244l.256.512a2.25 2.25 0 002.013 1.244h3.218a2.25 2.25 0 002.013-1.244l.256-.512a2.25 2.25 0 012.013-1.244h3.859m-19.5.338V18a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18v-4.162c0-.224-.034-.447-.1-.661L19.24 5.338a2.25 2.25 0 00-2.15-1.588H6.911a2.25 2.25 0 00-2.15 1.588L2.35 13.177a2.25 2.25 0 00-.1.661z" />
        </svg>
        <h3 class="mt-3 text-sm font-semibold text-gray-900"><%= t('.no_bundles_title') %></h3>
        <p class="mt-1 text-sm text-gray-500"><%= @state.present? ? t('.no_filtered_bundles') : t('.no_bundles_message') %></p>
      </div>
    <% end %>

  </div>
</main>
