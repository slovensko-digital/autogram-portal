<%# locals: (bundle:) %>

<% if bundle.contracts.count > 1 %>
  <% if bundle.completed? %>
    <span class="inline-flex items-center shrink-0 whitespace-nowrap rounded-full border px-3 py-1 text-sm font-medium border-green-200 bg-green-50 text-green-700">
      <svg class="mr-1.5 h-4 w-4" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
      </svg>
      <%= t('.all_signed') %>
    </span>
  <% else %>
    <% signed_count = bundle.contracts.count { |c| !c.awaiting_signature? } %>
    <span class="inline-flex items-center shrink-0 whitespace-nowrap rounded-full border px-3 py-1 text-sm font-medium border-yellow-200 bg-yellow-50 text-yellow-700">
      <svg class="mr-1.5 h-4 w-4" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/>
      </svg>
      <%= t('.signed_count', signed: signed_count, total: bundle.contracts.count) %>
    </span>
  <% end %>
<% end %>
